# Environment Variables — TaskFlow Dashboard
# Copy this file to .env and fill in any values as needed.
# This project is a fully client-side SPA; no server secrets are required.

# ── Vite Build Configuration ──────────────────────────────────────────────────

# The port the Vite development server listens on
VITE_PORT=5173

# Base URL for deployment (default: '/')
# Change to '/subdirectory/' if hosting in a non-root path
VITE_BASE_URL=/

# Node environment — set to 'production' for Docker builds
NODE_ENV=development

# ── Application Settings ──────────────────────────────────────────────────────

# The localStorage key used to persist tasks (do not change after deployment
# or existing user data will not be found)
VITE_STORAGE_KEY=kanban_dashboard_tasks
